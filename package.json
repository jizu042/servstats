{
  "name": "servstats",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "web",
    "server",
    "worker"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:web dev:server",
    "dev:web": "npm --workspace web run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm run build:web && npm run build:server",
    "build:web": "npm --workspace web run build",
    "build:server": "npm --workspace server run build",
    "start": "npm --workspace server run start",
    "start:worker": "npm --workspace worker run start",
    "postinstall": "npm rebuild --workspace web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}

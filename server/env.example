# Copy to .env locally. On Render, set these in the service dashboard (secrets marked sync: false in render.yaml).
PORT=8787
NODE_ENV=development
SESSION_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Optional: Postgres + Redis (Render attaches DATABASE_URL / REDIS_URL)
# DATABASE_URL=
# REDIS_URL=

# ismcserver.online API (same token as worker if you use auto source)
ISMCSERVER_TOKEN=

# Ely.by OAuth — redirect URI must match the URL of THIS API + /api/auth/ely/callback
ELY_OAUTH_CLIENT_ID=
ELY_OAUTH_CLIENT_SECRET=
ELY_OAUTH_REDIRECT_URI=http://localhost:8787/api/auth/ely/callback

API_SOURCE_PREFERENCE=auto
POLL_TIMEOUT_MS=8000
